# {{ ansible_managed }}
# Reverse proxy nginx pour l'application FastAPI

upstream fastapi_backend {
    server {{ webserver_upstream_host }}:{{ webserver_upstream_port }};
    keepalive 16;
}

server {
    listen {{ webserver_listen_port }} default_server;
    server_name {{ webserver_server_name }};

    access_log /var/log/nginx/fastapi.access.log;
    error_log  /var/log/nginx/fastapi.error.log;

    client_max_body_size 10M;

    location /health {
        proxy_pass http://fastapi_backend/health;
        access_log off;
    }

    location / {
        proxy_pass http://fastapi_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection        "";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
