[Unit]
Description=FastAPI application ({{ app_env.APP_NAME | default('fastapi') }})
After=network.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ app_dir }}
EnvironmentFile={{ app_config_dir }}/fastapi.env
ExecStart={{ app_venv_dir }}/bin/uvicorn main:app \
          --host {{ app_bind_host }} \
          --port {{ app_bind_port }} \
          --workers {{ app_workers }}
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
